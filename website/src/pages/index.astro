---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<main class="min-h-screen bg-slate-50 text-slate-800 font-sans">
		<nav class="sticky top-0 z-50 border-b border-slate-200 bg-slate-50/95 backdrop-blur">
			<div class="mx-auto flex w-[min(1100px,calc(100%-48px))] flex-wrap items-center justify-between gap-3 py-3">
				<a href="#" class="text-sm font-bold tracking-[-0.01em] text-slate-800">Kanji Go</a>
				<div class="flex flex-wrap items-center gap-2 text-sm">
					<a class="rounded-md px-2 py-1 text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900" href="#tinh-nang"
						>Tính năng</a
					>
					<a class="rounded-md px-2 py-1 text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900" href="#cai-dat"
						>Cài đặt</a
					>
					<a class="rounded-md px-2 py-1 text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900" href="#su-dung"
						>Cách dùng</a
					>
					<a
						class="rounded-md px-2 py-1 text-slate-600 transition-colors hover:bg-slate-100 hover:text-slate-900"
						href="#quyen-rieng-tu">Quyền riêng tư</a
					>
					<a
						class="ml-1 inline-flex items-center justify-center rounded-md border border-rose-300 bg-rose-50 px-2.5 py-1 text-rose-700 transition-colors hover:bg-rose-100"
						href="https://github.com/ayakase/kanji-go"
						target="_blank"
						rel="noopener noreferrer"
					>
						<svg
							class="mr-1.5 size-4"
							viewBox="0 -0.5 25 25"
							fill="currentColor"
							xmlns="http://www.w3.org/2000/svg"
							aria-hidden="true"
						>
							<path
								d="m12.301 0h.093c2.242 0 4.34.613 6.137 1.68l-.055-.031c1.871 1.094 3.386 2.609 4.449 4.422l.031.058c1.04 1.769 1.654 3.896 1.654 6.166 0 5.406-3.483 10-8.327 11.658l-.087.026c-.063.02-.135.031-.209.031-.162 0-.312-.054-.433-.144l.002.001c-.128-.115-.208-.281-.208-.466 0-.005 0-.01 0-.014v.001q0-.048.008-1.226t.008-2.154c.007-.075.011-.161.011-.249 0-.792-.323-1.508-.844-2.025.618-.061 1.176-.163 1.718-.305l-.076.017c.573-.16 1.073-.373 1.537-.642l-.031.017c.508-.28.938-.636 1.292-1.058l.006-.007c.372-.476.663-1.036.84-1.645l.009-.035c.209-.683.329-1.468.329-2.281 0-.045 0-.091-.001-.136v.007c0-.022.001-.047.001-.072 0-1.248-.482-2.383-1.269-3.23l.003.003c.168-.44.265-.948.265-1.479 0-.649-.145-1.263-.404-1.814l.011.026c-.115-.022-.246-.035-.381-.035-.334 0-.649.078-.929.216l.012-.005c-.568.21-1.054.448-1.512.726l.038-.022-.609.384c-.922-.264-1.981-.416-3.075-.416s-2.153.152-3.157.436l.081-.02q-.256-.176-.681-.433c-.373-.214-.814-.421-1.272-.595l-.066-.022c-.293-.154-.64-.244-1.009-.244-.124 0-.246.01-.364.03l.013-.002c-.248.524-.393 1.139-.393 1.788 0 .531.097 1.04.275 1.509l-.01-.029c-.785.844-1.266 1.979-1.266 3.227 0 .025 0 .051.001.076v-.004c-.001.039-.001.084-.001.13 0 .809.12 1.591.344 2.327l-.015-.057c.189.643.476 1.202.85 1.693l-.009-.013c.354.435.782.793 1.267 1.062l.022.011c.432.252.933.465 1.46.614l.046.011c.466.125 1.024.227 1.595.284l.046.004c-.431.428-.718 1-.784 1.638l-.001.012c-.207.101-.448.183-.699.236l-.021.004c-.256.051-.549.08-.85.08-.022 0-.044 0-.066 0h.003c-.394-.008-.756-.136-1.055-.348l.006.004c-.371-.259-.671-.595-.881-.986l-.007-.015c-.198-.336-.459-.614-.768-.827l-.009-.006c-.225-.169-.49-.301-.776-.38l-.016-.004-.32-.048c-.023-.002-.05-.003-.077-.003-.14 0-.273.028-.394.077l.007-.003q-.128.072-.08.184c.039.086.087.16.145.225l-.001-.001c.061.072.13.135.205.19l.003.002.112.08c.283.148.516.354.693.603l.004.006c.191.237.359.505.494.792l.01.024.16.368c.135.402.38.738.7.981l.005.004c.3.234.662.402 1.057.478l.016.002c.33.064.714.104 1.106.112h.007c.045.002.097.002.15.002.261 0 .517-.021.767-.062l-.027.004.368-.064q0 .609.008 1.418t.008.873v.014c0 .185-.08.351-.208.466h-.001c-.119.089-.268.143-.431.143-.075 0-.147-.011-.214-.032l.005.001c-4.929-1.689-8.409-6.283-8.409-11.69 0-2.268.612-4.393 1.681-6.219l-.032.058c1.094-1.871 2.609-3.386 4.422-4.449l.058-.031c1.739-1.034 3.835-1.645 6.073-1.645h.098-.005zm-7.64 17.666q.048-.112-.112-.192-.16-.048-.208.032-.048.112.112.192.144.096.208-.032zm.497.545q.112-.08-.032-.256-.16-.144-.256-.048-.112.08.032.256.159.157.256.047zm.48.72q.144-.112 0-.304-.128-.208-.272-.096-.144.08 0 .288t.272.112zm.672.673q.128-.128-.064-.304-.192-.192-.32-.048-.144.128.064.304.192.192.32.044zm.913.4q.048-.176-.208-.256-.24-.064-.304.112t.208.24q.24.097.304-.096zm1.009.08q0-.208-.272-.176-.256 0-.256.176 0 .208.272.176.256.001.256-.175zm.929-.16q-.032-.176-.288-.144-.256.048-.224.24t.288.128.225-.224z"
							></path>
						</svg>
						GitHub</a
					>
					<a
						class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-2.5 py-1 text-slate-700 transition-colors hover:bg-slate-100"
						href="/login"
						>Login</a
					>
					<a
						class="inline-flex items-center justify-center rounded-md border border-rose-400 bg-rose-400 px-2.5 py-1 font-semibold text-white transition-colors hover:bg-rose-500"
						href="/register"
						>Register</a
					>
				</div>
			</div>
		</nav>
		<header class="border-b border-slate-200 pb-10 pt-14 md:pt-[72px]">
			<div class="mx-auto grid w-[min(1100px,calc(100%-48px))] items-center gap-7 md:grid-cols-[1.15fr_0.85fr]">
				<div>
					<p class="mb-3.5 inline-flex items-center gap-2.5 text-xs uppercase tracking-[0.12em] text-slate-500">
						Tiện ích trình duyệt
					</p>
					<h1 class="m-0 text-[clamp(42px,4.8vw,64px)] leading-[1.03] tracking-[-0.03em]">Kanji Go</h1>
					<p class="mt-3.5 max-w-[58ch] text-base leading-relaxed text-slate-600">
						Tra từ Nhật nhanh ngay trên trang bạn đang đọc. Chỉ cần bôi đen hoặc rê chuột - nghĩa, cách đọc, và
						ví dụ hiện ra tức thì.
					</p>
					<div class="mt-[22px] flex flex-wrap gap-3">
						<a
							class="inline-flex items-center justify-center rounded-lg border border-rose-400 bg-rose-400 px-3.5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-rose-500"
							href="#cai-dat">Cài đặt</a
						>
						<a
							class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-100"
							href="#tinh-nang">Xem tính năng</a
						>
					</div>
					<ul class="mt-[18px] grid gap-2.5 text-sm text-slate-700">
						<li class="flex items-center gap-2.5">
							<span class="size-2 rounded-full bg-rose-400"></span>
							Tra nhanh bằng bôi đen / hover
						</li>
						<li class="flex items-center gap-2.5">
							<span class="size-2 rounded-full bg-emerald-500"></span>
							Gọn nhẹ, không làm gián đoạn việc đọc
						</li>
						<li class="flex items-center gap-2.5">
							<span class="size-2 rounded-full bg-amber-500"></span>
							Tôn trọng quyền riêng tư
						</li>
					</ul>
				</div>

				<div class="justify-self-start md:justify-self-end" role="img" aria-label="Minh hoạ popup tra từ">
					<div class="w-full max-w-[420px] overflow-hidden rounded-xl border border-slate-200 bg-white shadow-sm">
						<div class="flex items-center justify-between border-b border-slate-200 bg-slate-50/70 px-3.5 py-3">
							<span class="rounded-full border border-slate-300 bg-white px-2.5 py-1.5 text-xs font-semibold text-slate-700"
								>選択 / Hover</span
							>
							<span class="rounded-full border border-rose-200 bg-rose-50 px-2.5 py-1.5 text-xs font-semibold text-rose-700"
								>Kanji Go</span
							>
						</div>
						<div class="px-4 pb-3.5 pt-4">
							<div class="text-3xl font-extrabold tracking-[-0.02em]">勉強</div>
							<div class="mt-1.5 text-slate-500">べんきょう</div>
							<div class="mt-2.5 text-[15px] text-slate-800">học tập; học hành</div>
							<div class="my-3.5 h-px bg-slate-200"></div>
							<div class="grid gap-1.5 text-[13px] text-slate-600">
								<span class="text-slate-700">毎日、日本語を勉強しています。</span>
								<span class="text-slate-500">Mỗi ngày mình đều học tiếng Nhật.</span>
							</div>
						</div>
						<div class="flex items-center justify-between border-t border-slate-200 bg-slate-50/70 px-3.5 py-3">
							<span class="text-xs text-slate-500">Nhấn Esc để đóng</span>
							<span class="text-xs text-slate-500">Enter để ghim</span>
						</div>
					</div>
				</div>
			</div>
		</header>

		<section id="tinh-nang" class="border-b border-slate-200 py-[54px]">
			<div class="mx-auto w-[min(1100px,calc(100%-48px))]">
				<h2 class="mb-[18px] text-[26px] tracking-[-0.02em]">Tính năng nổi bật</h2>
				<div class="grid grid-cols-1 gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
					<article class="rounded-xl border border-rose-100 bg-rose-50/40 p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Tra ngay tại chỗ</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Bôi đen từ/cụm từ hoặc rê chuột để xem popup. Không cần chuyển tab, không mất nhịp đọc.
						</p>
					</article>
					<article class="rounded-xl border border-emerald-100 bg-emerald-50/40 p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Thông tin rõ ràng</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Hiển thị cách đọc, nghĩa, và ví dụ theo bố cục dễ nhìn - phù hợp cả người mới học lẫn nâng cao.
						</p>
					</article>
					<article class="rounded-xl border border-sky-100 bg-sky-50/40 p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Tuỳ chọn linh hoạt</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Bật/tắt hover, điều chỉnh hành vi popup, và chọn cách tra phù hợp với thói quen của bạn.
						</p>
					</article>
					<article class="rounded-xl border border-amber-100 bg-amber-50/45 p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Nhanh & gọn</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Giao diện tối giản, phản hồi nhanh. Ưu tiên trải nghiệm: ít "phiền", nhiều thông tin đúng lúc.
						</p>
					</article>
					<article class="rounded-xl border border-violet-100 bg-violet-50/40 p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Tôn trọng quyền riêng tư</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Không thu thập dữ liệu cá nhân một cách không cần thiết. Bạn chủ động trong việc sử dụng và chia sẻ.
						</p>
					</article>
					<article class="rounded-xl border border-teal-100 bg-teal-50/40 p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Phù hợp mọi trang</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Dùng tốt khi đọc báo, tài liệu, blog, hoặc bất kỳ nội dung tiếng Nhật nào trên web.
						</p>
					</article>
				</div>
			</div>
		</section>

		<section id="cai-dat" class="border-b border-slate-200 py-[54px]">
			<div class="mx-auto w-[min(1100px,calc(100%-48px))]">
				<h2 class="mb-[18px] text-[26px] tracking-[-0.02em]">Cài đặt</h2>
				<div class="mt-4 grid gap-3">
					<div class="grid grid-cols-[40px_1fr] items-start gap-3 rounded-xl border border-rose-100 bg-rose-50/40 p-3.5">
						<div
							class="grid size-9 place-items-center rounded-full border border-rose-200 bg-white text-sm font-extrabold text-rose-700"
						>
							1
						</div>
						<div>
							<h3 class="mb-2 text-base tracking-[-0.01em]">Thêm tiện ích</h3>
							<p class="m-0 leading-relaxed text-slate-600">Cài từ cửa hàng tiện ích của trình duyệt (Chrome/Firefox).</p>
						</div>
					</div>
					<div class="grid grid-cols-[40px_1fr] items-start gap-3 rounded-xl border border-emerald-100 bg-emerald-50/40 p-3.5">
						<div
							class="grid size-9 place-items-center rounded-full border border-emerald-200 bg-white text-sm font-extrabold text-emerald-700"
						>
							2
						</div>
						<div>
							<h3 class="mb-2 text-base tracking-[-0.01em]">Mở trang tiếng Nhật</h3>
							<p class="m-0 leading-relaxed text-slate-600">Ví dụ: bài báo, truyện, tài liệu học tập.</p>
						</div>
					</div>
					<div class="grid grid-cols-[40px_1fr] items-start gap-3 rounded-xl border border-sky-100 bg-sky-50/40 p-3.5">
						<div
							class="grid size-9 place-items-center rounded-full border border-sky-200 bg-white text-sm font-extrabold text-sky-700"
						>
							3
						</div>
						<div>
							<h3 class="mb-2 text-base tracking-[-0.01em]">Bôi đen hoặc hover</h3>
							<p class="m-0 leading-relaxed text-slate-600">Popup hiện ra với nghĩa, cách đọc, và ví dụ.</p>
						</div>
					</div>
				</div>
				<div class="mt-[22px] flex flex-wrap justify-center gap-3">
					<a
						class="inline-flex items-center justify-center rounded-lg border border-rose-400 bg-rose-400 px-3.5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-rose-500"
						href="#su-dung">Cách dùng nhanh</a
					>
					<a
						class="inline-flex items-center justify-center rounded-lg border border-slate-300 bg-white px-3.5 py-2.5 text-sm font-semibold text-slate-700 transition-colors hover:bg-slate-100"
						href="#quyen-rieng-tu">Quyền riêng tư</a
					>
				</div>
			</div>
		</section>

		<section id="su-dung" class="border-b border-slate-200 py-[54px]">
			<div class="mx-auto w-[min(1100px,calc(100%-48px))]">
				<h2 class="mb-[18px] text-[26px] tracking-[-0.02em]">Cách dùng nhanh</h2>
				<div class="mt-4 grid grid-cols-1 gap-3.5 md:grid-cols-2">
					<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Bôi đen để tra</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Khi gặp từ mới, hãy bôi đen. Popup sẽ hiện ngay cạnh vùng chọn để bạn xem nghĩa và cách đọc.
						</p>
					</div>
					<div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
						<h3 class="mb-2 text-base tracking-[-0.01em]">Hover để tra</h3>
						<p class="m-0 leading-relaxed text-slate-600">
							Nếu bạn thích tra "nhẹ nhàng" hơn, bật chế độ hover để xem nhanh khi rê chuột qua từ.
						</p>
					</div>
				</div>
			</div>
		</section>

		<section id="quyen-rieng-tu" class="border-b border-slate-200 py-[54px]">
			<div class="mx-auto w-[min(1100px,calc(100%-48px))]">
				<h2 class="mb-[18px] text-[26px] tracking-[-0.02em]">Quyền riêng tư</h2>
				<p class="m-0 leading-relaxed text-slate-600">
					Kanji Go được thiết kế để hỗ trợ việc học mà không gây lo lắng về dữ liệu. Nếu dự án của bạn có trang
					chính sách riêng tư/nguồn mở, bạn có thể liên kết tại đây.
				</p>
				<div class="mt-3.5 rounded-xl border border-dashed border-amber-300 bg-amber-50 p-3.5">
					<p class="m-0 text-[13px] leading-relaxed text-amber-800">
						Gợi ý: thêm link tới trang GitHub, chính sách quyền riêng tư, và trang cửa hàng tiện ích để tăng độ tin cậy.
					</p>
				</div>
			</div>
		</section>

		<footer class="pb-11 pt-8.5">
			<div class="mx-auto flex w-[min(1100px,calc(100%-48px))] flex-wrap items-center justify-between gap-3">
				<p class="m-0 inline-flex items-center gap-2.5 font-extrabold tracking-[-0.01em]">
					<span class="size-2 rounded-full bg-rose-400" aria-hidden="true"></span>
					Kanji Go
				</p>
				<p class="m-0 text-[13px] text-slate-500">Tra từ Nhật nhanh ngay trên web.</p>
			</div>
		</footer>
	</main>
</Layout>
